APP_ID=
APP_NAME=Coolify
APP_ENV=production
APP_KEY=base64:replace_with_a_generated_app_key
APP_PORT=8080
COOLIFY_BIND_ADDRESS=127.0.0.1

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=coolify
DB_USERNAME=coolify
DB_PASSWORD=replace_with_a_strong_database_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_a_strong_redis_password

PUSHER_APP_ID=replace_with_a_random_app_id
PUSHER_APP_KEY=replace_with_a_random_app_key
PUSHER_APP_SECRET=replace_with_a_random_app_secret

SOKETI_PORT=6001
SOKETI_METRICS_PORT=6002
SOKETI_DEBUG=false

REGISTRY_URL=ghcr.io
LATEST_IMAGE=latest

# Local DinD deployment target exposed through the outer coolify-target container.
# Coolify UI remains on localhost:8080. Apps deployed inside the target can bind
# HTTP_PORT=8080 and will be reachable from Windows/WSL at localhost:18080.
LOCAL_APP_HTTP_PORT=18080
TARGET_APP_HTTP_PORT=8080
LOCAL_TARGET_SSH_PORT=2222
COOLIFY_USER_PASSWORD=replace_with_a_local_target_password
COOLIFY_PUBLIC_KEY=

# Optional: pre-create the first admin user by filling these before first boot.
ROOT_USERNAME=
ROOT_USER_EMAIL=
ROOT_USER_PASSWORD=
